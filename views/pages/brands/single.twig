{% extends 'layouts/master.twig' %}

{% block title %}{{ brand.name ?: 'Brand' }}{% endblock %}

{% block content %}
  <section class="lore-section">
    <div class="lore-container lore-surface lore-product-info">
      {% component breadcrumbs %}
      <h1 class="lore-section-title">{{ brand.name ?: 'Brand' }}</h1>
      <p class="lore-copy">{{ brand.description ?: 'Brand page ready for Salla catalog content.' }}</p>
      <div style="margin-top:24px;">
        <salla-products-list source="brands" source-value="{{ brand.id }}" limit="8"></salla-products-list>
      </div>
    </div>
  </section>
{% endblock %}
