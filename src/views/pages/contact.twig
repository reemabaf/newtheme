{% extends 'layouts/master.twig' %}

{% block title %}Contact{% endblock %}

{% block content %}
  <section class="lore-section">
    <div class="lore-container">
      {% component breadcrumbs %}
      <div class="lore-section-header">
        <div>
          <p class="lore-eyebrow">Contact</p>
          <h1 class="lore-section-title">We'd love to hear from you.</h1>
          <p class="lore-section-copy">Questions about an order, a future collection, or a custom request? Send us a note and our team will get back to you soon.</p>
        </div>
      </div>

      <div class="lore-grid-2">
        <article class="lore-contact-card">
          <div class="lore-form-grid">
            <input class="lore-form-control" type="text" placeholder="First name">
            <input class="lore-form-control" type="text" placeholder="Last name">
            <input class="lore-form-control" type="email" placeholder="Email address" style="grid-column: 1 / -1;">
            <textarea placeholder="Tell us how we can help." style="grid-column: 1 / -1;"></textarea>
          </div>
          <div style="margin-top: 18px;">
            <button class="lore-pill lore-pill--primary" type="button">Send message</button>
          </div>
        </article>

        <article class="lore-contact-card">
          <p class="lore-eyebrow" style="color: var(--lore-stone);">FAQ Preview</p>
          <div class="lore-copy">
            <h2 class="lore-card-title" style="font-size: 28px;">Do your phone cases fit multiple models?</h2>
            <p>Each case is offered in selected models, and available options are listed on the product page.</p>
            <h2 class="lore-card-title" style="font-size: 28px;">Are the stickers waterproof?</h2>
            <p>Our sticker sets are made with durable laminated finishes designed for everyday use.</p>
            <h2 class="lore-card-title" style="font-size: 28px;">Do you release limited collections?</h2>
            <p>Yes. Some themed drops are seasonal and only available while inventory lasts.</p>
          </div>
        </article>
      </div>
    </div>
  </section>
{% endblock %}
