{% extends 'layouts/master.twig' %}

{% block title %}{{ store.name ?: 'LORE' }}{% endblock %}

{% block content %}
  <section class="lore-section">
    <div class="lore-container">
      <div class="lore-surface lore-hero">
        <div>
          <p class="lore-eyebrow">Curated for screen obsessions</p>
          <h1 class="lore-title">
            {{ store.name ?: 'LORE' }}
            <span>{{ theme.settings.get('hero_title') ?: 'Phone cases & stickers inspired by the stories you love.' }}</span>
          </h1>
          <p class="lore-copy">
            Fashion-forward accessories for cinema lovers, series collectors, and anyone who wants their everyday essentials to feel intentional, elevated, and unmistakably modern.
          </p>
          <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:28px;">
            <a class="lore-pill lore-pill--primary" href="/products">{{ trans('lore.shop_now') ?: 'Shop now' }}</a>
            <a class="lore-pill lore-pill--secondary" href="/page/about">{{ trans('lore.discover_brand') ?: 'Discover the brand' }}</a>
          </div>
        </div>

        <div class="lore-hero-grid">
          <article class="lore-feature-card">
            <p class="lore-eyebrow" style="color: var(--lore-stone);">Best seller</p>
            <div>
              <h2 class="lore-card-title" style="font-size: 38px;">Midnight Reel</h2>
              <p class="lore-card-copy">Noir-inspired finishes, sculpted camera cutouts, and a polished feel made for after-dark wardrobes.</p>
            </div>
            <div class="lore-feature-card--dark" style="padding:20px;border-radius:24px;">
              <p class="lore-eyebrow" style="color: rgba(255,255,255,.74);">Editorial object</p>
              <p style="margin:12px 0 0;font-size:28px;">A case that feels collectible.</p>
            </div>
          </article>

          <div style="display:grid;gap:16px;">
            <article class="lore-mini-card">
              <p class="lore-eyebrow" style="color: var(--lore-stone);">New drop</p>
              <h3 class="lore-card-title" style="font-size: 30px;">Series Mood</h3>
              <p class="lore-card-copy">Sticker storytelling with polished typography and collector energy.</p>
            </article>
            <article class="lore-mini-card" style="background: var(--lore-cream);">
              <p class="lore-eyebrow" style="color: var(--lore-stone);">Curated themes</p>
              <h3 class="lore-card-title" style="font-size: 30px;">From cult classics to soft-focus romance.</h3>
              <p class="lore-card-copy">Build your phone and desk edit around the scenes you never forgot.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container">
      <div class="lore-section-header">
        <div>
          <p class="lore-eyebrow">{{ trans('lore.featured_collections') ?: 'Featured collections' }}</p>
          <h2 class="lore-section-title">Curated edits shaped by genre, mood, and visual culture.</h2>
          <p class="lore-section-copy">Each collection is built like a cinematic wardrobe with refined color stories, collectible details, and accessories that feel polished from first glance.</p>
        </div>
      </div>

      <div class="lore-grid-3">
        {% set collections = [
          {'title': 'Premiere Night', 'copy': 'Statement cases for the main-character entrance.', 'image': 'images/collection-premiere.svg'},
          {'title': 'Episode Edit', 'copy': 'Sticker sets for cult-series devotion with a refined edge.', 'image': 'images/collection-episode.svg'},
          {'title': 'After Hours', 'copy': 'Moody palettes and sleek finishes inspired by late-night screenings.', 'image': 'images/collection-after-hours.svg'}
        ] %}

        {% for collection in collections %}
          <article class="lore-collection">
            <div class="lore-card-media">
              <img src="{{ collection.image | asset }}" alt="{{ collection.title }}">
            </div>
            <div class="lore-card-body">
              <p class="lore-eyebrow" style="color: var(--lore-stone);">Collection</p>
              <h3 class="lore-card-title" style="font-size: 30px; margin-top: 10px;">{{ collection.title }}</h3>
              <p class="lore-card-copy">{{ collection.copy }}</p>
              <a class="lore-pill lore-pill--secondary" href="/products" style="margin-top:12px;">Explore</a>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container">
      <div class="lore-promo">
        <p class="lore-eyebrow">Promotion</p>
        <h2 class="lore-section-title" style="margin-top: 10px;">Build your signature set.</h2>
        <p class="lore-copy">Buy any phone case and get 20% off a matching sticker set. Designed to pair like a complete story edit.</p>
        <a class="lore-pill lore-pill--primary" href="/products" style="margin-top: 12px;">Shop the set</a>
      </div>
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container">
      <div class="lore-section-header">
        <div>
          <p class="lore-eyebrow">{{ trans('lore.best_sellers') ?: 'Best sellers' }}</p>
          <h2 class="lore-section-title">Products from your Salla catalog will appear here.</h2>
          <p class="lore-section-copy">This section is wired for Salla and should use your live store products instead of the static React mock data.</p>
        </div>
      </div>
      <div class="lore-surface" style="padding: 22px;">
        <salla-products-list source="latest" limit="6" autoload></salla-products-list>
      </div>
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container">
      <div class="lore-section-header">
        <div>
          <p class="lore-eyebrow">{{ trans('lore.shop_category') ?: 'Shop by category' }}</p>
          <h2 class="lore-section-title">Choose your everyday icon.</h2>
          <p class="lore-section-copy">Build your own cinematic edit with collectible stickers and premium cases designed to travel with you.</p>
        </div>
      </div>
      <div class="lore-grid-2">
        <article class="lore-mini-card">
          <p class="lore-eyebrow" style="color: var(--lore-stone);">Category 01</p>
          <h3 class="lore-card-title" style="font-size: 32px;">Phone Cases</h3>
          <p class="lore-card-copy">Protective silhouettes with editorial styling.</p>
          <a class="lore-pill lore-pill--secondary" href="/products">Browse cases</a>
        </article>
        <article class="lore-mini-card">
          <p class="lore-eyebrow" style="color: var(--lore-stone);">Category 02</p>
          <h3 class="lore-card-title" style="font-size: 32px;">Stickers</h3>
          <p class="lore-card-copy">Collectible sets inspired by scenes, scripts, and moodboards.</p>
          <a class="lore-pill lore-pill--secondary" href="/products">Browse stickers</a>
        </article>
      </div>
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container">
      <div class="lore-section-header">
        <div>
          <p class="lore-eyebrow">{{ trans('lore.testimonials') ?: 'Testimonials' }}</p>
          <h2 class="lore-section-title">A premium feel fans notice immediately.</h2>
        </div>
      </div>
      <div class="lore-grid-3">
        {% set testimonials = [
          {'title': 'Feels like a fashion accessory', 'copy': 'The case quality is beautiful and the design feels so elevated. It looks premium, not overly fandom-driven.', 'name': 'Lina A.'},
          {'title': 'Exactly the aesthetic I wanted', 'copy': 'The sticker pack is polished, chic, and still full of personality. Everything about the packaging feels intentional.', 'name': 'Noura K.'},
          {'title': 'Beautiful gift-worthy details', 'copy': 'LORE has that rare mix of minimal design and pop-culture energy. It feels like a boutique brand I found early.', 'name': 'Sara M.'}
        ] %}
        {% for review in testimonials %}
          <article class="lore-review">
            <p style="color:var(--lore-accent);font-size:18px;">★★★★★</p>
            <h3 class="lore-card-title" style="font-size: 30px;">{{ review.title }}</h3>
            <p class="lore-card-copy">{{ review.copy }}</p>
            <p class="lore-eyebrow" style="color: var(--lore-stone);">{{ review.name }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container">
      <div class="lore-section-header">
        <div>
          <p class="lore-eyebrow">Gallery</p>
          <h2 class="lore-section-title">An Instagram-style glimpse into the LORE world.</h2>
        </div>
      </div>
      <div class="lore-gallery-strip">
        <img src="{{ 'images/gallery-shot-one.svg' | asset }}" alt="Gallery one">
        <img src="{{ 'images/gallery-shot-two.svg' | asset }}" alt="Gallery two">
        <img src="{{ 'images/gallery-shot-three.svg' | asset }}" alt="Gallery three">
        <img src="{{ 'images/gallery-shot-four.svg' | asset }}" alt="Gallery four">
      </div>
    </div>
  </section>
{% endblock %}
