<!doctype html>
<html lang="{{ locale.code ?: 'en' }}" dir="{{ locale.direction ?: 'ltr' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ page.title ?: store.name ?: 'LORE' }}{% endblock %}</title>
    <link rel="icon" href="{{ 'images/favicon.svg' | asset }}">
    <link rel="stylesheet" href="{{ 'styles/lore.css' | asset }}">
    <style>
      :root {
        --lore-accent: {{ theme.settings.get('accent_color') ?: '#4A235D' }};
        --lore-cream: {{ theme.settings.get('surface_color') ?: '#F7F0E8' }};
      }
    </style>
    {% block head %}{% endblock %}
    {% hook 'head:start' %}
    {% hook 'head:end' %}
  </head>
  <body>
    {% hook 'body:start' %}
    {% include 'components/common/header.twig' %}

    <main>
      {% block content %}{% endblock %}
    </main>

    <section class="lore-section">
      <div class="lore-container">
        <div class="lore-newsletter">
          <p class="lore-eyebrow" style="color: rgba(255,255,255,.72);">Join the list</p>
          <h2 class="lore-section-title" style="margin-top: 12px;">
            {{ theme.settings.get('newsletter_title') ?: 'Early access to new drops, curated edits, and story-led releases.' }}
          </h2>
          <p class="lore-copy">Subscribe for launch reminders, limited collection previews, and a first look at new accessories.</p>
          <form action="#" method="post">
            <input type="email" placeholder="{{ trans('lore.newsletter_placeholder') ?: 'Email address' }}">
            <button class="lore-pill lore-pill--secondary" type="submit">{{ trans('lore.newsletter_button') ?: 'Subscribe' }}</button>
          </form>
        </div>
      </div>
    </section>

    {% include 'components/common/footer.twig' %}
    {% hook 'body:end' %}
  </body>
</html>
