{% extends 'layouts/master.twig' %}

{% block title %}{{ product.name ?: store.name ?: 'LORE' }}{% endblock %}

{% block content %}
  <section class="lore-section">
    <div class="lore-container">
      {% component breadcrumbs %}
      <div class="lore-product-layout">
        <div class="lore-gallery">
          {% if product.images and product.images|length %}
            <img src="{{ product.images[0].url ?: product.images[0] }}" alt="{{ product.name }}">
            {% if product.images|length > 1 %}
              <div class="lore-grid-3" style="margin-top:16px;">
                {% for image in product.images|slice(1, 3) %}
                  <img src="{{ image.url ?: image }}" alt="{{ product.name }}">
                {% endfor %}
              </div>
            {% endif %}
          {% else %}
            <img src="{{ 'images/product-midnight-reel.svg' | asset }}" alt="{{ product.name ?: 'LORE product' }}">
          {% endif %}
        </div>

        <div class="lore-surface lore-product-info">
          <p class="lore-eyebrow">{{ product.brand.name ?: product.promotion_title ?: 'LORE' }}</p>
          <h1 class="lore-product-title">{{ product.name }}</h1>
          <p class="lore-product-price">
            {% if product.is_on_sale %}
              {{ product.sale_price ?: product.price }}
            {% else %}
              {{ product.price ?: product.price_formatted }}
            {% endif %}
          </p>
          {% if product.subtitle %}
            <p class="lore-copy">{{ product.subtitle }}</p>
          {% endif %}

          {% if product.description %}
            <div class="lore-copy">{{ product.description|raw }}</div>
          {% endif %}

          {% hook 'product:single.description.start' %}

          <form method="post" action="{{ product.url ?: '#' }}" style="margin-top:28px;">
            {% hook 'product:single.form.start' %}
            {% if product.options %}
              {% for option in product.options %}
                <div style="margin-bottom:16px;">
                  <label class="lore-eyebrow" style="color: var(--lore-stone);display:block;margin-bottom:8px;">{{ option.name }}</label>
                  <select class="lore-form-control">
                    {% for value in option.values %}
                      <option>{{ value.name ?: value }}</option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            {% endif %}

            <div style="margin-bottom:16px;">
              <label class="lore-eyebrow" style="color: var(--lore-stone);display:block;margin-bottom:8px;">Quantity</label>
              <salla-quantity-input value="1"></salla-quantity-input>
            </div>

            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              <salla-add-product product-id="{{ product.id }}" class="lore-pill lore-pill--primary"></salla-add-product>
              <a class="lore-pill lore-pill--secondary" href="/wishlist">Add to wishlist</a>
            </div>
            {% hook 'product:single.form.end' %}
          </form>

          <div class="lore-mini-card" style="margin-top:24px;background: var(--lore-cream);">
            <p class="lore-eyebrow" style="color: var(--lore-stone);">Why customers love it</p>
            <ul class="lore-list-reset lore-copy">
              <li>Premium protective shell with elevated finish</li>
              <li>Designed to feel collectible, polished, and gift-worthy</li>
              <li>Inspired by iconic visual storytelling and editorial styling</li>
            </ul>
          </div>

          <salla-social-share style="margin-top:18px;"></salla-social-share>
        </div>
      </div>
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container">
      {% component comments %}
    </div>
  </section>

  <section class="lore-section">
    <div class="lore-container lore-surface" style="padding: 24px;">
      <h2 class="lore-section-title" style="margin-bottom: 18px;">Related products</h2>
      <salla-products-list source="related" source-value="{{ product.id }}" limit="4"></salla-products-list>
    </div>
  </section>
{% endblock %}
