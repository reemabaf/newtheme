{% extends 'layouts/master.twig' %}

{% block title %}{{ page.title ?: 'Shop' }}{% endblock %}

{% block content %}
  <section class="lore-section">
    <div class="lore-container">
      {% component breadcrumbs %}
      <div class="lore-section-header">
        <div>
          <p class="lore-eyebrow">Shop</p>
          <h1 class="lore-section-title">{{ page.title ?: 'Cinematic accessories with a polished, fashion-forward edge.' }}</h1>
          <p class="lore-section-copy">Browse cases and sticker sets inspired by unforgettable scenes, iconic characters, and visual storytelling.</p>
        </div>
      </div>

      <div class="lore-shop-layout">
        <aside class="lore-surface lore-sidebar">
          <div class="lore-filter-group">
            <h3>Product type</h3>
            <label><input type="checkbox"> Phone Case</label>
            <label><input type="checkbox"> Sticker</label>
          </div>
          <div class="lore-filter-group">
            <h3>Theme</h3>
            <label><input type="checkbox"> Noir Cinema</label>
            <label><input type="checkbox"> Indie Drama</label>
            <label><input type="checkbox"> Cult Series</label>
          </div>
          <div class="lore-filter-group">
            <h3>Price</h3>
            <label><input type="checkbox"> Under 100 SAR</label>
            <label><input type="checkbox"> 100 - 200 SAR</label>
            <label><input type="checkbox"> 200+ SAR</label>
          </div>
        </aside>

        <div class="lore-surface lore-product-panel">
          <salla-products-list source="search" autoload filters-results includes='["images","options"]'></salla-products-list>
        </div>
      </div>
    </div>
  </section>
{% endblock %}
