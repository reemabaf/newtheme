{% extends 'layouts/master.twig' %}

{% block title %}{{ page.title ?: store.name ?: 'LORE' }}{% endblock %}

{% block content %}
  <section class="lore-section">
    <div class="lore-container">
      {% component breadcrumbs %}
      <div class="lore-grid-2">
        <article class="lore-contact-card">
          <p class="lore-eyebrow">Brand story</p>
          <h1 class="lore-section-title">{{ page.title ?: 'Inspired by iconic stories, cinema, and visual culture.' }}</h1>
          <div class="lore-copy">
            {% if page.content %}
              {{ page.content|raw }}
            {% else %}
              <p>LORE creates modern accessories for people who love film, television, and design in equal measure. We believe fandom can feel elevated, polished, and beautifully wearable.</p>
              <p>Our collections are built from cinematic moodboards, title sequences, gallery palettes, and the textures of unforgettable scenes.</p>
            {% endif %}
          </div>
        </article>

        <article class="lore-contact-card">
          <img src="{{ 'images/about-lore.svg' | asset }}" alt="{{ page.title ?: 'LORE' }}">
        </article>
      </div>
    </div>
  </section>
{% endblock %}
