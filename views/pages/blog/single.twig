{% extends 'layouts/master.twig' %}

{% block title %}{{ page.title ?: 'Article' }}{% endblock %}

{% block content %}
  <section class="lore-section">
    <div class="lore-container lore-surface lore-product-info">
      {% component breadcrumbs %}
      <h1 class="lore-section-title">{{ page.title ?: 'Article' }}</h1>
      <div class="lore-copy">{{ page.content|default('Add your editorial article content here.')|raw }}</div>
    </div>
  </section>
{% endblock %}
